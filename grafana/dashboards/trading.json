{
  "uid": "trading-monitor",
  "title": "Trading Monitor",
  "description": "随机模拟交易程序监控面板 — 价格、持仓、盈亏、成交次数",
  "tags": ["trading", "demo"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "2s",
  "time": {
    "from": "now-5m",
    "to": "now"
  },
  "timepicker": {},
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "资产价格",
      "description": "随机游走模拟的资产价格，每秒更新",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus-trading" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-trading" },
          "expr": "trading_price",
          "legendFormat": "价格",
          "interval": ""
        }
      ],
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "none",
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "currencyUSD",
          "decimals": 4
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "持仓手数",
      "description": "正数=多头，负数=空头，0=空仓",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus-trading" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-trading" },
          "expr": "trading_position",
          "legendFormat": "持仓手数",
          "interval": ""
        }
      ],
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 20,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0 },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "未实现盈亏 (Unrealized P&L)",
      "description": "当前持仓的浮动盈亏：(当前价 - 开仓均价) × 持仓手数",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-trading" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-trading" },
          "expr": "trading_pnl",
          "legendFormat": "P&L",
          "interval": ""
        }
      ],
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 20,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "currencyUSD",
          "decimals": 4,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 0 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "累计成交次数",
      "description": "程序启动后的累计成交笔数（Counter，重启后归零）",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-trading" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-trading" },
          "expr": "trading_trades_total",
          "legendFormat": "成交笔数",
          "instant": true,
          "interval": ""
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "unit": "short",
          "decimals": 0,
          "mappings": []
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "table",
      "title": "实时套利信号看板 (Live Arbitrage Board)",
      "description": "当前活跃的期权套利信号，按预期收益降序排列。信号消失后自动移除。",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus-trading" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-trading" },
          "expr": "option_arbitrage_profit > 0",
          "instant": true,
          "range": false,
          "legendFormat": "{{contract_id}}",
          "interval": ""
        }
      ],
      "transformations": [
        {
          "id": "labelsToFields",
          "options": { "mode": "columns" }
        },
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "job": true,
              "instance": true,
              "__name__": true
            },
            "renameByName": {
              "contract_id":   "合约 ID",
              "strategy_type": "套利类型",
              "expiry":        "到期日",
              "Value":         "预期收益 ($)"
            },
            "indexByName": {
              "contract_id":   0,
              "strategy_type": 1,
              "expiry":        2,
              "Value":         3
            }
          }
        }
      ],
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "预期收益 ($)", "desc": true }],
        "footer": { "show": false, "reducer": ["sum"], "countRows": false, "enablePagination": false }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto",
            "filterable": true
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "预期收益 ($)" },
            "properties": [
              { "id": "unit", "value": "currencyUSD" },
              { "id": "decimals", "value": 2 },
              { "id": "custom.displayMode", "value": "color-background" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "gray",       "value": null },
                    { "color": "yellow",     "value": 50   },
                    { "color": "green",      "value": 100  },
                    { "color": "dark-green", "value": 500  }
                  ]
                }
              },
              { "id": "color", "value": { "mode": "thresholds" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "合约 ID" },
            "properties": [{ "id": "custom.width", "value": 230 }]
          },
          {
            "matcher": { "id": "byName", "options": "套利类型" },
            "properties": [{ "id": "custom.width", "value": 180 }]
          },
          {
            "matcher": { "id": "byName", "options": "到期日" },
            "properties": [{ "id": "custom.width", "value": 120 }]
          }
        ]
      }
    }
  ]
}
