# ── 基础镜像 ──────────────────────────────────────────────────────────────────
FROM python:3.13-slim

# ── 注入 uv ───────────────────────────────────────────────────────────────────
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

# ── 虚拟环境路径 ──────────────────────────────────────────────────────────────
# 将 venv 放在 /opt/venv 而非工作目录内，避免被 Dev Container 的 bind mount 遮盖
ENV UV_PROJECT_ENVIRONMENT=/opt/venv

# ── 工作目录 ──────────────────────────────────────────────────────────────────
WORKDIR /app

# ── 安装依赖（利用 Docker 层缓存）────────────────────────────────────────────
# 先只复制 pyproject.toml，依赖不变时此层会被缓存
COPY pyproject.toml .
RUN uv sync --no-install-project

# ── 复制源代码 ────────────────────────────────────────────────────────────────
COPY app.py serve.py ./

# ── 暴露端口 ──────────────────────────────────────────────────────────────────
EXPOSE 8080

# ── 容器启动入口 ──────────────────────────────────────────────────────────────
# serve.py 启动 textual-serve，监听 0.0.0.0:8080
# textual-serve 为每个浏览器连接 fork 子进程执行 app.py
ENTRYPOINT ["/opt/venv/bin/python", "serve.py"]
